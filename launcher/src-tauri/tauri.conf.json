{
  "$schema": "https://raw.githubusercontent.com/nicholasmoser/gnt-docs/main/.schemas/tauri.conf.v2.json",
  "productName": "HowlingWind",
  "version": "0.2.7",
  "identifier": "com.howlingwind.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HowlingWind",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 550
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
